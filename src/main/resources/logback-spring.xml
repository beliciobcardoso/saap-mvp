<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Propriedades padrao (podem ser sobrescritas via variaveis de ambiente) -->
    <property name="LOG_DIR" value="${LOG_DIR:-logs}"/>
    <property name="LOG_FILE" value="${LOG_FILE:-saap-mvp}"/>
    <property name="LOG_MAX_HISTORY" value="${LOG_MAX_HISTORY:-30}"/>
    <property name="LOG_MAX_SIZE" value="${LOG_MAX_SIZE:-50MB}"/>
    <property name="LOG_TOTAL_SIZE_CAP" value="${LOG_TOTAL_SIZE_CAP:-2GB}"/>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{traceId}] %-5level [%thread] %logger{36} - %msg%n"/>

    <!-- Logger raiz: nivel INFO padrao -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- ──────────────────────────────────────────────────────
         Hibernate 7 - constraint violations (duplicate key)
         sao tratadas via DataIntegrityViolationException.
         Suprimimos o WARN para evitar poluicao nos logs.
         ────────────────────────────────────────────────────── -->
    <logger name="org.hibernate.orm.jdbc.error" level="ERROR"/>

    <!-- ──────────────────────────────────────────────────────
         Spring / Flyway / Tomcat
         ────────────────────────────────────────────────────── -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.flywaydb" level="INFO"/>
    <logger name="org.apache" level="WARN"/>

    <!-- ══════════════════════════════════════════════════════
         Profile: dev - verbose, com Hibernate SQL
         ══════════════════════════════════════════════════════ -->
    <springProfile name="dev">
        <logger name="br.com.belloinfo.saap_mvp" level="DEBUG"/>
        <logger name="org.springframework.web" level="INFO"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.hibernate.orm.jdbc.bind" level="TRACE"/>
    </springProfile>

    <!-- ══════════════════════════════════════════════════════
         Profile: prod - silencioso + arquivo rotativo
         ══════════════════════════════════════════════════════ -->
    <springProfile name="prod">

        <!-- Appender de arquivo rotativo (data + tamanho) -->
        <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/${LOG_FILE}.log</file>

            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/${LOG_FILE}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
                <maxFileSize>${LOG_MAX_SIZE}</maxFileSize>
                <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
            </rollingPolicy>

            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="ROLLING_FILE"/>
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="br.com.belloinfo.saap_mvp" level="INFO"/>
        <logger name="org.hibernate.SQL" level="OFF"/>
        <logger name="org.hibernate.orm.jdbc.bind" level="OFF"/>
    </springProfile>

</configuration>
