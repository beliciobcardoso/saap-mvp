# Copie este arquivo para application-local.yaml e configure suas credenciais locais.
# O arquivo application-local.yaml está no .gitignore e não será enviado ao repositório.

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/saap_db
    username: seu_usuario_postgres
    password: sua_senha_postgres
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  flyway:
    enabled: true
