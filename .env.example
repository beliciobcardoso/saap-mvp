# =============================================================================
# SAAP MVP - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# Valores entre colchetes sao os padrões usados quando a variável nao e definida.
# =============================================================================

# --- Banco de Dados ----------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saap_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# --- Porta do Servidor -------------------------------------------------------
PORT=8080

# --- Redis (blacklist de tokens JWT, opcional) -------------------------------
# REDIS_ENABLED: se false, blacklist usa fallback em memoria (nao serve p/ multi-instancia)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000

# --- Segurança / JWT [OBRIGATÓRIO] ------------------------------------------
# JWT_SECRET: segredo para assinatura dos tokens JWT de autenticação.
#             Deve ter pelo menos 32 caracteres.
#             Gere com: openssl rand -hex 32
JWT_SECRET=

# ACTION_TOKEN_SECRET: segredo separado para tokens de ação (confirmação/cancelamento por e-mail).
#                      Deve ter pelo menos 32 caracteres e ser DIFERENTE do JWT_SECRET.
#                      Gere com: openssl rand -hex 32
ACTION_TOKEN_SECRET=

# Tempo de expiração em milissegundos [86400000 = 24h]
JWT_EXPIRATION=86400000
ACTION_TOKEN_EXPIRATION=86400000

# --- Aplicação ---------------------------------------------------------------
APP_BASE_URL=http://localhost:8080

# Origens permitidas para CORS (separadas por virgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Agendador (Scheduler) ---------------------------------------------------
# Cron para processamento de follow-ups [padrão: a cada hora]
FOLLOW_UP_CRON=0 0 * * * *

# --- Configurações da Clinica ------------------------------------------------
# Janela de confirmação do agendamento em horas [48]
CLINIC_CONFIRMATION_WINDOW_HOURS=48

# Prazo de follow-up da clinica em horas [24]
CLINIC_FOLLOW_UP_DEADLINE_HOURS=24

# Cancelar automaticamente agendamentos nao confirmados [true]
CLINIC_AUTO_CANCEL=true

# --- JPA / Hibernate (opcional) ----------------------------------------------
SPRING_JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=true
FLYWAY_ENABLED=true

# --- Notificações (Email, WhatsApp, SMS) ------------------------------------
# Habilitar/desabilitar notificações [true]
APP_NOTIFICATIONS_ENABLED=true

# Email via SMTP [pode ser OCI Email Delivery, SendGrid SMTP, ou outro]
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@saap.local

# Twilio para WhatsApp e SMS [opcional]
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
