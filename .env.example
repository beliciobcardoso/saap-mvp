# Configuração de Banco de Dados Local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saap_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Configurações de Log e JPA
SPRING_JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=true
FLYWAY_ENABLED=true

# Porta do Servidor Tomcat
PORT=8080

# Configurações do JWT Security
# openssl rand -hex 32 ou openssl rand -base64 32
JWT_SECRET=meu_segredo_super_secreto_para_assinatura_do_token_jwt
# Tempo de expiração do token em milissegundos (ex: 86400000 = 1 dia)
JWT_EXPIRATION=86400000

# Configuração do Cron para Follow Up
# um intervalo curto, ex: "*/30 * * * * *" para rodar a cada 30s
# um intervalo mais longo, ex: "0 0 * * * *" para rodar a cada hora
FOLLOW_UP_CRON=*/30 * * * * *

# Configuração da URL base do aplicativo
APP_BASE_URL=http://localhost:8080

# Origens permitidas para CORS (separadas por vírgula)
# Em produção, liste as origens exatas do frontend, ex: https://app.seudominio.com.br
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Configuração da janela de confirmação da clínica em horas
CLINIC_CONFIRMATION_WINDOW_HOURS=48

# Configuração do prazo de follow-up da clínica em horas
CLINIC_FOLLOW_UP_DEADLINE_HOURS=24

# Configuração para cancelar automaticamente consultas não confirmadas
CLINIC_AUTO_CANCEL=true