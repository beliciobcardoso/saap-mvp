# =============================================================================
# SAAP MVP - Variaveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# Valores entre colchetes sao os padroes usados quando a variavel nao e definida.
# =============================================================================

# --- Banco de Dados ----------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saap_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# --- Porta do Servidor -------------------------------------------------------
PORT=8080

# --- Seguranca / JWT [OBRIGATORIO] ------------------------------------------
# JWT_SECRET: segredo para assinatura dos tokens JWT de autenticacao.
#             Deve ter pelo menos 32 caracteres.
#             Gere com: openssl rand -hex 32
JWT_SECRET=

# ACTION_TOKEN_SECRET: segredo separado para tokens de acao (confirmacao/cancelamento por e-mail).
#                      Deve ter pelo menos 32 caracteres e ser DIFERENTE do JWT_SECRET.
#                      Gere com: openssl rand -hex 32
ACTION_TOKEN_SECRET=

# Tempo de expiracao em milissegundos [86400000 = 24h]
JWT_EXPIRATION=86400000
ACTION_TOKEN_EXPIRATION=86400000

# --- Aplicacao ---------------------------------------------------------------
APP_BASE_URL=http://localhost:8080

# Origens permitidas para CORS (separadas por virgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Agendador (Scheduler) ---------------------------------------------------
# Cron para processamento de follow-ups [padrao: a cada hora]
FOLLOW_UP_CRON=0 0 * * * *

# --- Configuracoes da Clinica ------------------------------------------------
# Janela de confirmacao do agendamento em horas [48]
CLINIC_CONFIRMATION_WINDOW_HOURS=48

# Prazo de follow-up da clinica em horas [24]
CLINIC_FOLLOW_UP_DEADLINE_HOURS=24

# Cancelar automaticamente agendamentos nao confirmados [true]
CLINIC_AUTO_CANCEL=true

# --- JPA / Hibernate (opcional) ----------------------------------------------
SPRING_JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=true
FLYWAY_ENABLED=true

# --- Notificacoes (Email, WhatsApp, SMS) ------------------------------------
# Email via SMTP [pode ser OCI Email Delivery, SendGrid SMTP, ou outro]
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@saap.local

# Twilio para WhatsApp e SMS [opcional]
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
