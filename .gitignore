# =========================================================================
# Spring Boot / Maven Git Ignore
# =========================================================================

# Build Target
target/
build/
bin/
out/
*.class

# Maven Wrapper
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/

# Local Environment and Secrets
.env
.env.local
.env.*.local
*.local
application-local.properties
application-local.yml
application-local.yaml
spring.log

# Logs
*.log
logs/
**/logs/
temp/
tmp/

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Code Editors
# -------------------------------------------------------------------------

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
*.classes

# Eclipse / Spring Tool Suite (STS)
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# Visual Studio Code
.vscode/

# Crash and Heap Dumps
*.hprof
*.err
